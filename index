<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบคัดกรองการได้ยิน รพ.ศรีสังวรสุโขทัย</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Sarabun', sans-serif; }
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  </style>

  <!-- Import Map for React and ReactDOM -->
  <script type="importmap">
  {
    "imports": {
      "react": "https://esm.sh/react@18.2.0",
      "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
      "react-dom": "https://esm.sh/react-dom@18.2.0"
    }
  }
  </script>
  
  <!-- Babel for JSX Compiling in Browser -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="bg-slate-100 font-sans text-slate-800 selection:bg-teal-200 min-h-screen">
  
  <!-- จุดที่ React จะไปแสดงผล -->
  <div id="root"></div>

  <!-- โค้ด Application -->
  <script type="text/babel" data-type="module">
    import React, { useState, useEffect } from 'react';
    import { createRoot } from 'react-dom/client';
    import * as lucideReact from 'https://esm.sh/lucide-react@0.294.0?external=react';
    
    const { Ear, Phone, Users, Tv, Brain, RotateCcw, VolumeX, MessageSquare, Frown, MapPin, CheckCircle, AlertTriangle, Home, BarChart2, Settings, Trash2, Save, User, Calendar, XCircle, Stethoscope, ChevronRight, Sparkles, Bot, Loader2, Lock, Key } = lucideReact;

    // --- ตั้งค่า URL ของ Google Apps Script (นำ URL ของคุณมาใส่ตรงนี้) ---
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbx08ig6B1SWMX7VNHrQqYn0XgYto8oCxZKeKWgLpErAfVr4l1B56aNOUqpURZ7fQY8q/exec";
    // ไม่จำเป็นต้องใช้ apiKey ในฝั่ง Frontend แล้วครับ เพราะเราย้ายไปรันบน GAS

    // --- ชุดคำถาม ---
    const defaultQuestions = [
      { id: 1, text: 'ฉันมีปัญหาในการคุยโทรศัพท์ ได้ยินไม่ชัด', icon: <Phone className="w-8 h-8 mb-2" /> },
      { id: 2, text: 'เมื่อมีการคุยกันมากกว่า 2 คน ฉันลำบากในการทำความเข้าใจเรื่องที่คุย', icon: <Users className="w-8 h-8 mb-2" /> },
      { id: 3, text: 'คนรอบข้างบอกว่าฉันเปิดทีวีเสียงดัง', icon: <Tv className="w-8 h-8 mb-2" /> },
      { id: 4, text: 'ฉันรู้สึกเครียด ต้องพยายามทำความเข้าใจเรื่องที่พูดคุย', icon: <Brain className="w-8 h-8 mb-2" /> },
      { id: 5, text: 'ฉันได้ยินคำพูดไม่ชัด ต้องขอให้พูดซ้ำ', icon: <RotateCcw className="w-8 h-8 mb-2" /> },
      { id: 6, text: 'เมื่อคุยในที่มีเสียงรบกวน เช่นที่ประชุม งานเลี้ยง ฉันได้ยินคำพูดไม่ชัด', icon: <VolumeX className="w-8 h-8 mb-2" /> },
      { id: 7, text: 'ฉันตอบไม่ตรงกับคำถาม', icon: <MessageSquare className="w-8 h-8 mb-2" /> },
      { id: 8, text: 'คนรอบข้างเบื่อรำคาญ ที่ฉันฟังไม่เข้าใจ', icon: <Frown className="w-8 h-8 mb-2" /> },
      { id: 9, text: 'ฉันสับสนไม่รู้ว่าเสียงมาจากทางไหน', icon: <MapPin className="w-8 h-8 mb-2" /> },
      { id: 10, text: 'ข้อนี้ขอให้คนในครอบครัวตอบ คุณคิดว่าคนนี้มีปัญหาการได้ยินหรือไม่', icon: <Ear className="w-8 h-8 mb-2" />, isFamily: true }
    ];

    const defaultUnits = [
      "รพ. ศรีสังวร", "รพ.สต.คลองตาล", "รพ.สต.บ้านไร่", "รพ.สต.วัดเกาะ", 
      "รพ.สต.เกาะตาเลี้ยง", "สอ.ต.นาขุนไกร", "รพ.สต.วังทอง", "รพ.สต.บ้านวงฆ้อง", 
      "รพ.สต.บ้านซ่าน", "รพ.สต.ราวต้นจันทร์", "เครือข่ายศรีสัชนาลัย", 
      "เครือข่ายสวรรคโลก", "เครือข่ายทุ่งเสลี่ยม", "เครือข่ายศรีนคร"
    ];

    function App() {
      const [view, setView] = useState('home'); 
      const [records, setRecords] = useState([]);
      
      const [settings, setSettings] = useState({
        projectName: "โครงการตรวจการได้ยินเชิงรุกเพื่อค้นหาผู้พิการทางการได้ยิน",
        departmentName: "กลุ่มงานโสต ศอ นาสิก รพ.ศรีสังวรสุโขทัย",
        units: defaultUnits
      });
      const [tempSettings, setTempSettings] = useState(settings);
      const [newUnit, setNewUnit] = useState('');

      const [patientInfo, setPatientInfo] = useState({ name: '', age: '', phone: '', address: '', unit: '' });
      const [answers, setAnswers] = useState(Array(10).fill(null));
      const [score, setScore] = useState(0);

      const [aiAdvice, setAiAdvice] = useState('');
      const [isAiAdviceLoading, setIsAiAdviceLoading] = useState(false);
      const [aiSummary, setAiSummary] = useState('');
      const [isAiSummaryLoading, setIsAiSummaryLoading] = useState(false);

      const [customAiQuery, setCustomAiQuery] = useState('');
      const [customAiResponse, setCustomAiResponse] = useState('');
      const [isCustomAiLoading, setIsCustomAiLoading] = useState(false);

      const [isAdmin, setIsAdmin] = useState(false);
      const [adminPassword, setAdminPassword] = useState('122244444');
      const [showAuthModal, setShowAuthModal] = useState(false);
      const [authTargetView, setAuthTargetView] = useState('');
      const [authMode, setAuthMode] = useState('login'); 
      const [authInput, setAuthInput] = useState({ username: '', password: '', pin: '', newPassword: '' });
      const [authError, setAuthError] = useState('');

      useEffect(() => {
        const savedRecords = JSON.parse(localStorage.getItem('hearingRecords')) || [];
        const savedSettings = JSON.parse(localStorage.getItem('hearingSettings'));
        const savedAdminPassword = localStorage.getItem('adminPassword');
        
        setRecords(savedRecords);
        if (savedSettings) {
          setSettings(savedSettings);
          setTempSettings(savedSettings); 
        }
        if (savedAdminPassword) setAdminPassword(savedAdminPassword);
      }, []);

      const saveSettings = (newSettings) => {
        setSettings(newSettings);
        localStorage.setItem('hearingSettings', JSON.stringify(newSettings));
      };

      const handleSaveSettingsAction = () => {
        saveSettings(tempSettings);
        alert('บันทึกการตั้งค่าเรียบร้อยแล้ว');
      };

      const addUnit = () => {
        if(newUnit.trim()) {
          setTempSettings({...tempSettings, units: [...tempSettings.units, newUnit.trim()]});
          setNewUnit('');
        }
      };

      const removeUnit = (index) => {
        const updated = tempSettings.units.filter((_, i) => i !== index);
        setTempSettings({...tempSettings, units: updated});
      };

      const fetchGemini = async (prompt, systemInstruction = "คุณคือผู้ช่วย AI") => {
        if (!GOOGLE_SCRIPT_URL || GOOGLE_SCRIPT_URL === "") {
          return "เกิดข้อผิดพลาด: ไม่พบการเชื่อมต่อกับ Google Apps Script";
        }
        
        try {
          // เตรียมข้อมูลเพื่อส่งให้ GAS (ตรงตามที่เขียนรับไว้ใน GAS.txt)
          const payload = {
            action: "analyze",
            prompt: prompt,
            systemInstruction: systemInstruction
          };

          const res = await fetch(GOOGLE_SCRIPT_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' }, // ใช้ text/plain เพื่อป้องกันปัญหา CORS
            body: JSON.stringify(payload)
          });
          
          const data = await res.json();
          
          // ตรวจสอบผลลัพธ์จาก GAS
          if (data.result === "success") {
            return data.ai_response;
          } else {
            throw new Error(data.error || 'Unknown Error from GAS');
          }
        } catch (err) {
          return `เกิดข้อผิดพลาดในการวิเคราะห์: ${err.message}`;
        }
      };

      const handleStart = () => {
        setPatientInfo({ name: '', age: '', phone: '', address: '', unit: '' });
        setAnswers(Array(10).fill(null));
        setAiAdvice(''); 
        setView('prescreen');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      const handlePreScreen = (status) => {
        if (status === 'pass') {
          setView('prescreen_reject');
        } else {
          setView('form');
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      const handleAnswer = (index, value) => {
        const newAnswers = [...answers];
        newAnswers[index] = value;
        setAnswers(newAnswers);
      };

      const handleSubmit = (e) => {
        e.preventDefault();
        if (answers.includes(null)) {
          alert("กรุณาตอบคำถามให้ครบทุกข้อครับ");
          return;
        }

        const totalScore = answers.reduce((a, b) => a + b, 0);
        setScore(totalScore);

        let statusText = 'ปกติ';
        if (totalScore >= 16) {
          statusText = 'เสี่ยงสูง';
        } else if (totalScore >= 11) {
          statusText = 'เสี่ยงปานกลาง';
        }

        const newRecord = {
          id: Date.now(),
          date: new Date().toLocaleString('th-TH'),
          ...patientInfo,
          score: totalScore,
          status: statusText,
          q1: answers[0], q2: answers[1], q3: answers[2], q4: answers[3], q5: answers[4],
          q6: answers[5], q7: answers[6], q8: answers[7], q9: answers[8], q10: answers[9]
        };

        const updatedRecords = [newRecord, ...records];
        setRecords(updatedRecords);
        localStorage.setItem('hearingRecords', JSON.stringify(updatedRecords));
        
        if (GOOGLE_SCRIPT_URL !== "") {
          fetch(GOOGLE_SCRIPT_URL, { 
            method: 'POST', 
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify(newRecord) 
          }).catch(err => console.error('Error saving sheet:', err));
        }

        setView('result');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      const deleteRecord = (id) => {
        if(window.confirm("ต้องการลบข้อมูลนี้ใช่หรือไม่?")) {
          const updated = records.filter(r => r.id !== id);
          setRecords(updated);
          localStorage.setItem('hearingRecords', JSON.stringify(updated));
        }
      };

      const handleNavigation = (target) => {
        if (target === 'dashboard' || target === 'settings') {
          if (isAdmin) {
            setView(target);
            if (target === 'dashboard') setAiSummary('');
            if (target === 'settings') setTempSettings(settings); 
          } else {
            setAuthTargetView(target);
            setShowAuthModal(true);
            setAuthMode('login');
            setAuthError('');
            setAuthInput({ username: '', password: '', pin: '', newPassword: '' });
          }
        } else {
          setView(target);
        }
      };

      const handleLogin = (e) => {
        e.preventDefault();
        if (authInput.username === 'admin' && authInput.password === adminPassword) {
          setIsAdmin(true);
          setShowAuthModal(false);
          setView(authTargetView);
          if (authTargetView === 'dashboard') setAiSummary('');
          if (authTargetView === 'settings') setTempSettings(settings);
        } else {
          setAuthError('Username หรือ Password ไม่ถูกต้อง!');
        }
      };

      const handleChangePassword = (e) => {
        e.preventDefault();
        if (authInput.pin === '1207') {
          if (authInput.newPassword.length < 4) {
            setAuthError('รหัสผ่านใหม่ต้องมีอย่างน้อย 4 ตัวอักษร');
            return;
          }
          setAdminPassword(authInput.newPassword);
          localStorage.setItem('adminPassword', authInput.newPassword);
          setAuthMode('login');
          setAuthError('');
          setAuthInput({ ...authInput, password: '', pin: '', newPassword: '' });
          alert('เปลี่ยนรหัสผ่านเรียบร้อยแล้ว กรุณาเข้าสู่ระบบด้วยรหัสผ่านใหม่');
        } else {
          setAuthError('PIN Code ไม่ถูกต้อง!');
        }
      };

      const handleGenerateAdvice = async () => {
        setIsAiAdviceLoading(true);
        const prompt = `ผู้ป่วยชื่อ ${patientInfo.name || 'คุณตา/คุณยาย'} อายุ ${patientInfo.age} ปี ทำแบบประเมินปัญหาการได้ยินได้คะแนน ${score}/20 (เกณฑ์ปกติ 0-10, เสี่ยงปานกลาง 11-15, เสี่ยงสูง 16-20) 
        กรุณาเขียนคำแนะนำการปฏิบัติตัวเบื้องต้นเกี่ยวกับการดูแลสุขภาพหู 3 ข้อสั้นๆ อ่านง่าย เป็นกันเองและให้กำลังใจ เหมาะสำหรับผู้สูงอายุ (หลีกเลี่ยงการวินิจฉัยทางการแพทย์เชิงลึก) โดยใช้ภาษาไทย และจัดรูปแบบให้อ่านง่าย`;
        
        const advice = await fetchGemini(prompt, "คุณคือแพทย์ผู้เชี่ยวชาญด้าน โสต ศอ นาสิก (ENT) ที่ใจดีและอธิบายเข้าใจง่าย");
        setAiAdvice(advice);
        setIsAiAdviceLoading(false);
      };

      const handleGenerateSummary = async () => {
        setIsAiSummaryLoading(true);
        const riskCount = records.filter(r => r.score >= 11).length;
        const normalCount = records.length - riskCount;
        const avgAge = records.length > 0 ? (records.reduce((acc, curr) => acc + Number(curr.age), 0) / records.length).toFixed(1) : 0;
        
        const prompt = `จากข้อมูลการคัดกรองการได้ยินจำนวน ${records.length} คน พบผู้ที่มีความเสี่ยง (คะแนน 11-20) ${riskCount} คน และอยู่ในเกณฑ์ปกติ (คะแนน 0-10) ${normalCount} คน อายุเฉลี่ยของผู้เข้ารับการตรวจคือ ${avgAge} ปี 
        กรุณาวิเคราะห์และสรุปภาพรวมสั้นๆ ประมาณ 3-4 บรรทัด ว่าแนวโน้มเป็นอย่างไร และให้ข้อเสนอแนะ 1 ข้อสำหรับเจ้าหน้าที่สาธารณสุขในการลงพื้นที่ครั้งต่อไป`;
        
        const summary = await fetchGemini(prompt, "คุณคือนักวิเคราะห์ข้อมูลสาธารณสุขระดับเชี่ยวชาญ");
        setAiSummary(summary);
        setIsAiSummaryLoading(false);
      };

      const handleCustomAiQuery = async () => {
        if(!customAiQuery.trim()) return;
        setIsCustomAiLoading(true);
        const riskRecords = records.filter(r => r.score >= 11);
        
        let riskDataText = riskRecords.map(r => `- อายุ ${r.age} ปี, หน่วย: ${r.unit}, คะแนน: ${r.score} (${r.status})`).join('\n');
        if(!riskDataText) riskDataText = "ไม่มีข้อมูลผู้มีความเสี่ยงในขณะนี้";

        const prompt = `ข้อมูลผู้มีความเสี่ยงการได้ยิน (คะแนน 11-20) จำนวน ${riskRecords.length} คน มีดังนี้:\n${riskDataText}\n\nคำถามจากเจ้าหน้าที่ผู้คัดกรอง: ${customAiQuery}\n\nกรุณาตอบคำถามนี้โดยวิเคราะห์จากข้อมูลผู้มีความเสี่ยงด้านบน ให้คำตอบที่กระชับ เป็นรูปธรรม และนำไปปรับใช้ในการวางแผนสาธารณสุขได้จริง`;
        
        const response = await fetchGemini(prompt, "คุณคือนักวิเคราะห์ข้อมูลสาธารณสุขระดับเชี่ยวชาญ ที่ช่วยเจ้าหน้าที่วิเคราะห์ข้อมูลผู้ป่วยกลุ่มเสี่ยง");
        setCustomAiResponse(response);
        setIsCustomAiLoading(false);
      };

      let currentViewContent = null;

      if (view === 'home') {
        currentViewContent = (
          <div className="max-w-4xl mx-auto mt-12 p-6 text-center animate-fade-in">
            <div className="bg-white rounded-3xl shadow-xl p-8 md:p-16 transform transition hover:shadow-2xl relative overflow-hidden">
              <div className="absolute top-0 right-0 p-6 opacity-10"><Stethoscope className="w-48 h-48 text-teal-500" /></div>
              <Ear className="w-24 h-24 mx-auto text-teal-500 mb-6 animate-pulse" />
              <h2 className="text-3xl md:text-4xl font-bold text-slate-800 mb-4">ยินดีต้อนรับสู่ระบบคัดกรองการได้ยิน</h2>
              <p className="text-xl text-slate-600 mb-8 max-w-2xl mx-auto">
                ผู้รับการตรวจคัดกรองต้องมีหูได้ยินไม่ชัดทั้ง 2 ข้าง และเป็นมานานกว่า 4 เดือน 
              </p>
              <button 
                onClick={handleStart}
                className="bg-teal-600 hover:bg-teal-500 text-white text-2xl font-bold py-6 px-12 rounded-full shadow-lg hover:shadow-teal-500/50 hover:-translate-y-2 transition-all duration-300 flex items-center justify-center gap-3 mx-auto w-full md:w-auto z-10 relative"
              >
                <Stethoscope size={32} /> เริ่มทำแบบประเมิน
              </button>
            </div>
          </div>
        );
      } else if (view === 'prescreen') {
        currentViewContent = (
          <div className="max-w-3xl mx-auto mt-12 p-6 animate-fade-in">
            <div className="bg-white rounded-3xl shadow-xl p-8 text-center border-t-8 border-teal-500">
              <h2 className="text-3xl font-bold text-slate-800 mb-6">การทดสอบเบื้องต้น</h2>
              <p className="text-2xl text-teal-700 mb-8 p-4 bg-teal-50 rounded-xl font-medium">
                "เมื่อถูนิ้วห่างจากหน้าหูท่าน 1 นิ้ว ท่านได้ยินชัดกี่ข้าง?"
              </p>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <button onClick={() => handlePreScreen('pass')} className="group p-6 bg-slate-50 hover:bg-green-100 rounded-2xl border-2 border-slate-200 hover:border-green-500 transition-all duration-300 hover:scale-105 shadow-sm hover:shadow-md">
                  <Ear className="w-16 h-16 mx-auto text-slate-400 group-hover:text-green-600 mb-4" />
                  <h3 className="text-2xl font-bold text-slate-700 group-hover:text-green-700">ได้ยินเสียง 1 ข้าง</h3>
                </button>
                <button onClick={() => handlePreScreen('pass')} className="group p-6 bg-slate-50 hover:bg-green-100 rounded-2xl border-2 border-slate-200 hover:border-green-500 transition-all duration-300 hover:scale-105 shadow-sm hover:shadow-md">
                  <div className="flex justify-center gap-2 mb-4">
                    <Ear className="w-16 h-16 text-slate-400 group-hover:text-green-600" />
                    <Ear className="w-16 h-16 text-slate-400 group-hover:text-green-600" style={{transform: 'scaleX(-1)'}}/>
                  </div>
                  <h3 className="text-2xl font-bold text-slate-700 group-hover:text-green-700">ได้ยินเสียงทั้ง 2 ข้าง</h3>
                </button>
                <button onClick={() => handlePreScreen('fail')} className="group p-6 bg-slate-50 hover:bg-orange-100 rounded-2xl border-2 border-slate-200 hover:border-orange-500 transition-all duration-300 hover:scale-105 shadow-sm hover:shadow-md ring-4 ring-orange-200">
                  <div className="flex justify-center gap-2 mb-4 relative">
                    <Ear className="w-16 h-16 text-slate-400 group-hover:text-orange-600 opacity-50" />
                    <Ear className="w-16 h-16 text-slate-400 group-hover:text-orange-600 opacity-50" style={{transform: 'scaleX(-1)'}}/>
                    <XCircle className="w-8 h-8 text-red-500 absolute top-0 right-1/4" />
                  </div>
