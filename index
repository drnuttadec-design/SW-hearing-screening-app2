                      <div key={index} className="bg-white border border-slate-200 py-2 px-4 rounded-full flex items-center gap-2 shadow-sm text-slate-700 font-medium">
                        {unit}
                        <button onClick={() => removeUnit(index)} className="text-red-400 hover:text-red-600 bg-red-50 p-1 rounded-full"><XCircle size={16}/></button>
                      </div>
                    ))}
                  </div>
                </div>

                <button onClick={handleSaveSettingsAction} className="w-full mt-8 bg-teal-600 hover:bg-teal-500 text-white text-xl font-bold py-4 rounded-xl shadow-lg transition-all flex justify-center items-center gap-2">
                  <Save size={24}/> บันทึกการตั้งค่า
                </button>
              </div>
            </div>
          </div>
        );
      }

      return (
        <>
          <header className="bg-teal-700 text-white p-4 shadow-md sticky top-0 z-50">
            <div className="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between">
              <div className="flex items-center gap-4 mb-4 md:mb-0">
                <img src="sw logo vector.jpg" alt="รพ.ศรีสังวรสุโขทัย" className="w-16 h-16 bg-white rounded-full p-1 shadow-lg" onError={(e) => { e.target.onerror = null; e.target.src = "https://via.placeholder.com/150?text=Logo" }} />
                <div>
                  <h1 className="text-2xl font-bold">แบบทดสอบคัดกรองการได้ยิน</h1>
                  <p className="text-sm opacity-90">{settings.projectName}</p>
                </div>
              </div>
              <div className="flex gap-2">
                <button onClick={() => handleNavigation('home')} className="p-2 hover:bg-teal-600 rounded-lg flex items-center gap-1 transition-colors"><Home size={20}/> หน้าแรก</button>
                <button onClick={() => handleNavigation('dashboard')} className="p-2 hover:bg-teal-600 rounded-lg flex items-center gap-1 transition-colors"><BarChart2 size={20}/> ข้อมูล</button>
                <button onClick={() => handleNavigation('settings')} className="p-2 hover:bg-teal-600 rounded-lg flex items-center gap-1 transition-colors"><Settings size={20}/> ตั้งค่า</button>
                {isAdmin && (
                  <button onClick={() => { setIsAdmin(false); setView('home'); }} className="p-2 hover:bg-red-500 bg-red-600/80 rounded-lg flex items-center gap-1 transition-colors ml-2" title="ออกจากระบบ">
                    <Lock size={20}/>
                  </button>
                )}
              </div>
            </div>
          </header>
          
          <main className="pb-20">
            {currentViewContent}
          </main>

          <footer className="bg-slate-800 text-white p-8 mt-12">
            <div className="max-w-4xl mx-auto text-center space-y-2">
              <h3 className="text-xl font-semibold text-teal-400">{settings.departmentName}</h3>
              <p className="text-lg flex items-center justify-center gap-2"><Phone size={20} className="text-teal-400"/> 055-682030 ต่อ 1207</p>
              <p className="text-lg flex items-center justify-center gap-2"><MessageSquare size={20} className="text-green-400"/> LINE ID: @871ykqyc</p>
              <p className="text-sm text-slate-400 mt-4">พัฒนาเพื่อคุณภาพชีวิตที่ดีของผู้สูงวัย ✨ ขับเคลื่อนด้วย AI</p>
            </div>
          </footer>

          {showAuthModal && (
            <div className="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 animate-fade-in">
              <div className="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden">
                <div className="bg-teal-700 p-6 text-white text-center">
                  <Lock className="w-12 h-12 mx-auto mb-2 opacity-90" />
                  <h2 className="text-2xl font-bold">{authMode === 'login' ? 'เข้าสู่ระบบสำหรับเจ้าหน้าที่' : 'เปลี่ยนรหัสผ่าน'}</h2>
                </div>
                
                <div className="p-8">
                  {authError && (
                    <div className="bg-red-50 text-red-600 p-3 rounded-xl mb-6 text-center text-sm font-bold border border-red-200 flex items-center justify-center gap-2">
                      <AlertTriangle size={18} /> {authError}
                    </div>
                  )}

                  {authMode === 'login' ? (
                    <form onSubmit={handleLogin} className="space-y-5">
                      <div>
                        <label className="block text-slate-700 font-bold mb-2">Username</label>
                        <input required type="text" className="w-full p-3 border-2 border-slate-200 rounded-xl focus:border-teal-500 outline-none bg-slate-50 focus:bg-white transition-colors" value={authInput.username} onChange={e => setAuthInput({...authInput, username: e.target.value})} placeholder="กรอก Username" />
                      </div>
                      <div>
                        <label className="block text-slate-700 font-bold mb-2">Password</label>
                        <input required type="password" className="w-full p-3 border-2 border-slate-200 rounded-xl focus:border-teal-500 outline-none bg-slate-50 focus:bg-white transition-colors" value={authInput.password} onChange={e => setAuthInput({...authInput, password: e.target.value})} placeholder="•••••••••" />
                      </div>
                      <button type="submit" className="w-full bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg py-3 rounded-xl transition-all shadow-md">
                        เข้าสู่ระบบ
                      </button>
                      <div className="flex justify-between items-center mt-4">
                        <button type="button" onClick={() => { setAuthMode('change_password'); setAuthError(''); }} className="text-teal-600 hover:text-teal-800 text-sm font-medium flex items-center gap-1">
                          <Key size={16} /> เปลี่ยนรหัสผ่าน
                        </button>
                        <button type="button" onClick={() => setShowAuthModal(false)} className="text-slate-500 hover:text-slate-700 text-sm font-medium">
                          ยกเลิก
                        </button>
                      </div>
                    </form>
                  ) : (
                    <form onSubmit={handleChangePassword} className="space-y-5">
                      <div>
                        <label className="block text-slate-700 font-bold mb-2">PIN Code (สำหรับยืนยัน)</label>
                        <input required type="password" maxLength={4} className="w-full p-3 border-2 border-slate-200 rounded-xl focus:border-teal-500 outline-none bg-slate-50 focus:bg-white transition-colors" value={authInput.pin} onChange={e => setAuthInput({...authInput, pin: e.target.value})} placeholder="กรอก PIN 4 หลัก" />
                      </div>
                      <div>
                        <label className="block text-slate-700 font-bold mb-2">รหัสผ่านใหม่ (New Password)</label>
                        <input required type="password" className="w-full p-3 border-2 border-slate-200 rounded-xl focus:border-teal-500 outline-none bg-slate-50 focus:bg-white transition-colors" value={authInput.newPassword} onChange={e => setAuthInput({...authInput, newPassword: e.target.value})} placeholder="ตั้งรหัสผ่านใหม่" />
                      </div>
                      <button type="submit" className="w-full bg-orange-500 hover:bg-orange-400 text-white font-bold text-lg py-3 rounded-xl transition-all shadow-md">
                        ยืนยันเปลี่ยนรหัสผ่าน
                      </button>
                      <div className="text-center mt-4">
                        <button type="button" onClick={() => { setAuthMode('login'); setAuthError(''); }} className="text-slate-500 hover:text-slate-700 text-sm font-medium">
                          กลับไปหน้าเข้าสู่ระบบ
                        </button>
                      </div>
                    </form>
                  )}
                </div>
              </div>
            </div>
          )}
        </>
      );
    }

    const root = createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
